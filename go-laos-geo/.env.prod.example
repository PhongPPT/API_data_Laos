# ----------------------------------------------------
# ฐานข้อมูล Supabase (แก้ไขข้อมูลส่วนนี้ให้ตรงกับเว็บ Supabase)
# ----------------------------------------------------
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.xxxxxxxxxxxxx
DB_PASSWORD=your_supabase_password
DB_NAME=postgres
DB_SSLMODE=require

# ----------------------------------------------------
# Kong API Gateway Database (ตัวรันภายใน VMware)
# ----------------------------------------------------
KONG_PG_USER=kong
KONG_PG_PASSWORD=your_secure_kong_password

# ----------------------------------------------------
# Grafana Dashboard (รหัสผ่านสำหรับล็อกอินเข้าดูสถิติ)
# ----------------------------------------------------
GRAFANA_PASSWORD=your_grafana_password
